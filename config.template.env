# ============================================
# Pentest Kit Configuration
# ============================================
# Copy this file to config.env and fill in your values.
# NEVER commit config.env to git — it contains secrets!
# ============================================

# --------------------------
# Required: AI API Keys
# --------------------------
# Gemini generates attack payloads; Claude is the target
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --------------------------
# Required: Target Configuration
# --------------------------
# The system prompt your AI assistant uses (or a representative test version).
# Include canary values so the test can detect data leakage.
# Customize ASSISTANT_NAME, OWNER_NAME, ORG_NAME, and OWNER_EMAIL for your assistant.
ASSISTANT_NAME=99
OWNER_NAME=Kim Snyder
ORG_NAME=Meet the Moment
OWNER_EMAIL=kim@mtm.now

# --------------------------
# Required: Claude Model
# --------------------------
# Which Claude model to test against
CLAUDE_MODEL=claude-sonnet-4-20250514

# --------------------------
# Optional: Supabase (for infrastructure checks)
# --------------------------
# Only needed if running Layer 2 infrastructure checks
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_ACCESS_TOKEN=your-management-api-token
# SUPABASE_PROJECT_ID=your-project-id
