# ============================================
# AI Infrastructure Hardening Kit — Self-Test Config
# ============================================
# Copy this file to config.env and fill in your values.
# NEVER commit config.env — it contains API keys.
# config.env is in .gitignore by default.
# ============================================

# --------------------------
# Required: AI API Keys
# --------------------------
# Gemini (free tier works) generates attack payloads.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic runs the target model.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --------------------------
# Required: Target Persona
# --------------------------
# These values are used to construct the canary-loaded system prompt
# that the test attacks. Use any placeholder values — they do not need
# to match a real person or organization.
ASSISTANT_NAME=ExampleBot
OWNER_NAME=Example User
ORG_NAME=Example Organization
OWNER_EMAIL=user@example.com

# --------------------------
# Optional: Claude Model
# --------------------------
# Which Claude model to test against. Defaults to a recent Opus
# if not set. For security-sensitive deployments, test against the
# same model you use in production.
CLAUDE_MODEL=claude-opus-4-5-20260101
